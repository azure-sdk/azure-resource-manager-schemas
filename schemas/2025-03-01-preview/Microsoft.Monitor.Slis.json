{
  "id": "https://schema.management.azure.com/schemas/2025-03-01-preview/Microsoft.Monitor.Slis.json#",
  "title": "Microsoft.Monitor",
  "description": "Microsoft Monitor Resource Types",
  "$schema": "http://json-schema.org/draft-04/schema#",
  "extension_resourceDefinitions": {
    "slis": {
      "description": "Microsoft.Monitor/slis",
      "properties": {
        "apiVersion": {
          "enum": [
            "2025-03-01-preview"
          ],
          "type": "string"
        },
        "identity": {
          "description": "The managed service identities assigned to this resource.",
          "oneOf": [
            {
              "$ref": "#/definitions/ManagedServiceIdentity"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "name": {
          "description": "Name of the SLI that is given by the user.",
          "oneOf": [
            {
              "pattern": "^[a-zA-Z0-9][a-zA-Z0-9_()~-]{2,63}$",
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "properties": {
          "description": "The resource-specific properties for this resource.",
          "oneOf": [
            {
              "$ref": "#/definitions/SliResource"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "type": {
          "enum": [
            "Microsoft.Monitor/slis"
          ],
          "type": "string"
        }
      },
      "required": [
        "name",
        "properties",
        "apiVersion",
        "type"
      ],
      "type": "object"
    }
  },
  "definitions": {
    "AmwAccount": {
      "description": "Represents an Azure Monitor Workspace (AMW) account used for emitting metrics.",
      "properties": {
        "identity": {
          "description": "The ARM resource ID of the managed identity with access to the source account.",
          "type": "string"
        },
        "resourceId": {
          "description": "The ARM resource ID of the account where metrics are emitted.",
          "type": "string"
        }
      },
      "required": [
        "resourceId",
        "identity"
      ],
      "type": "object"
    },
    "Baseline": {
      "description": "Defines the target parameters for a Slo baseline.",
      "properties": {
        "evaluationCalculationType": {
          "description": "Specifies how evaluation is calculated, either based on calendar days or a rolling window.",
          "oneOf": [
            {
              "enum": [
                "CalendarDays",
                "RollingDays"
              ],
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "evaluationPeriodDays": {
          "description": "The time frame (in days) used for SLI evaluation.",
          "oneOf": [
            {
              "maximum": 90,
              "minimum": 1,
              "type": "integer"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "value": {
          "description": "The user-defined or Azure-defined target value used for comparison against the SLI value.",
          "oneOf": [
            {
              "maximum": 100,
              "minimum": 0,
              "type": "number"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "required": [
        "value",
        "evaluationPeriodDays",
        "evaluationCalculationType"
      ],
      "type": "object"
    },
    "BaselineProperties": {
      "description": "Defines the properties of a baseline.",
      "properties": {
        "baseline": {
          "description": "Defines the baseline target, which is compared against the SLI value to determine compliance.",
          "oneOf": [
            {
              "$ref": "#/definitions/Baseline"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "required": [
        "baseline"
      ],
      "type": "object"
    },
    "Condition": {
      "description": "Represents a filtering condition.",
      "properties": {
        "dimensionName": {
          "description": "Dimension name used in filtering.",
          "type": "string"
        },
        "operator": {
          "description": "Operator used in the filtering condition.",
          "oneOf": [
            {
              "enum": [
                "eq",
                "ne",
                "lt",
                "lte",
                "gt",
                "gte",
                "in",
                "notin",
                "startswith",
                "notstartswith",
                "contains",
                "notcontains"
              ],
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "samplingType": {
          "description": "Defines the sampling type.",
          "oneOf": [
            {
              "enum": [
                "Average",
                "Sum",
                "Count",
                "Min",
                "Max"
              ],
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "scalarFunction": {
          "description": "Scalar function applied for filtering.",
          "oneOf": [
            {
              "enum": [
                "max",
                "min",
                "avg",
                "sum"
              ],
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "value": {
          "description": "Value used in filtering. For most operators (eq, ne, lt, lte, gt, gte, startswith, notstartswith, contains, notcontains) this is a single value (for example \"GetContosoUsers\"). For the `in` and `notin` operators, multiple values must be joined by the delimiter `^^` (for example \"east^^west^^north\").",
          "type": "string"
        }
      },
      "required": [
        "operator",
        "value"
      ],
      "type": "object"
    },
    "ManagedServiceIdentity": {
      "description": "Managed service identity (system assigned and/or user assigned identities)",
      "properties": {
        "type": {
          "description": "Type of managed service identity (where both SystemAssigned and UserAssigned types are allowed).",
          "oneOf": [
            {
              "enum": [
                "None",
                "SystemAssigned",
                "UserAssigned",
                "SystemAssigned,UserAssigned"
              ],
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "userAssignedIdentities": {
          "description": "The set of user assigned identities associated with the resource. The userAssignedIdentities dictionary keys will be ARM resource ids in the form: '/subscriptions/{subscriptionId}/resourceGroups/{resourceGroupName}/providers/Microsoft.ManagedIdentity/userAssignedIdentities/{identityName}. The dictionary values can be empty objects ({}) in requests.",
          "oneOf": [
            {
              "additionalProperties": {
                "$ref": "#/definitions/UserAssignedIdentity"
              },
              "properties": {},
              "type": "object"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "required": [
        "type"
      ],
      "type": "object"
    },
    "Signal": {
      "description": "Represents a signal model used in SLI calculations.",
      "properties": {
        "signalFormula": {
          "description": "Mathematical formula used to combine multiple metrics.",
          "type": "string"
        },
        "signalSources": {
          "description": "Sources of metrics used for SLIs.",
          "oneOf": [
            {
              "items": {
                "$ref": "#/definitions/SignalSource"
              },
              "type": "array"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "required": [
        "signalSources",
        "signalFormula"
      ],
      "type": "object"
    },
    "SignalSource": {
      "description": "Represents a signal source used in SLIs.",
      "properties": {
        "filters": {
          "description": "Filters applied to modify signal values.",
          "oneOf": [
            {
              "items": {
                "$ref": "#/definitions/Condition"
              },
              "type": "array"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "metricName": {
          "description": "Name of the metric.",
          "type": "string"
        },
        "metricNamespace": {
          "description": "Namespace of the metric.",
          "type": "string"
        },
        "signalSourceId": {
          "description": "Unique identifier for the signal source.",
          "type": "string"
        },
        "sourceAmwAccountManagedIdentity": {
          "description": "Managed identity for authenticating the signal source.",
          "type": "string"
        },
        "sourceAmwAccountResourceId": {
          "description": "Resource ID of the source AMW account.",
          "type": "string"
        },
        "spatialAggregation": {
          "description": "Defines how measurements are aggregated across multiple time series.",
          "oneOf": [
            {
              "$ref": "#/definitions/SpatialAggregation"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "temporalAggregation": {
          "description": "Defines how measurements are aggregated over a specific time window within the same time series.",
          "oneOf": [
            {
              "$ref": "#/definitions/TemporalAggregation"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "required": [
        "signalSourceId",
        "sourceAmwAccountManagedIdentity",
        "sourceAmwAccountResourceId",
        "metricNamespace",
        "metricName",
        "filters",
        "spatialAggregation",
        "temporalAggregation"
      ],
      "type": "object"
    },
    "SliProperties": {
      "description": "Defines the properties of an SLI.",
      "properties": {
        "goodSignals": {
          "description": "Represents good signals used in request-based SLI calculations.",
          "oneOf": [
            {
              "$ref": "#/definitions/Signal"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "signals": {
          "description": "Signals used for window-based SLI calculations.",
          "oneOf": [
            {
              "$ref": "#/definitions/Signal"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "totalSignals": {
          "description": "Represents total signals used in request-based SLI calculations.",
          "oneOf": [
            {
              "$ref": "#/definitions/Signal"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "windowUptimeCriteria": {
          "description": "Defines the uptime criteria for window-based SLIs.",
          "oneOf": [
            {
              "$ref": "#/definitions/WindowUptimeCriteria"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "type": "object"
    },
    "SliResource": {
      "description": "Defines the root level properties of an SLI resource.",
      "properties": {
        "baselineProperties": {
          "description": "Defines the SLO baseline associated with the SLI.",
          "oneOf": [
            {
              "$ref": "#/definitions/BaselineProperties"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "category": {
          "description": "Specifies the category of the SLI, used to classify signals such as Availability and Latency.",
          "oneOf": [
            {
              "enum": [
                "Availability",
                "Latency"
              ],
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "description": {
          "description": "A user-provided description of the SLI, with a maximum length of 1000 characters.",
          "oneOf": [
            {
              "pattern": "^[\\s\\S]{0,1000}$",
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "destinationAmwAccounts": {
          "description": "Destination AMW accounts.",
          "oneOf": [
            {
              "items": {
                "$ref": "#/definitions/AmwAccount"
              },
              "type": "array"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "enableAlert": {
          "description": "A flag to determine whether alert is enabled.",
          "oneOf": [
            {
              "type": "boolean"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "evaluationType": {
          "description": "Determines how the SLI is evaluated—either based on request counts or time windows.",
          "oneOf": [
            {
              "enum": [
                "WindowBased",
                "RequestBased"
              ],
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "sliProperties": {
          "description": "Defines the SLI properties associated with the SLI.",
          "oneOf": [
            {
              "$ref": "#/definitions/SliProperties"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "required": [
        "description",
        "category",
        "evaluationType",
        "destinationAmwAccounts",
        "baselineProperties",
        "enableAlert",
        "sliProperties"
      ],
      "type": "object"
    },
    "SpatialAggregation": {
      "description": "Represents the spatial aggregation model.",
      "properties": {
        "dimensions": {
          "description": "Dimensions considered for spatial aggregation.",
          "oneOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "type": {
          "description": "Type of spatial aggregation.",
          "oneOf": [
            {
              "enum": [
                "Average",
                "Min",
                "Max",
                "Sum",
                "Count"
              ],
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "required": [
        "type",
        "dimensions"
      ],
      "type": "object"
    },
    "TemporalAggregation": {
      "description": "Represents temporal aggregation settings.",
      "properties": {
        "type": {
          "description": "Type of temporal aggregation.",
          "oneOf": [
            {
              "enum": [
                "Average",
                "Min",
                "Max",
                "Sum",
                "Rate",
                "IRate",
                "Delta",
                "IDelta",
                "Increase"
              ],
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "windowSizeMinutes": {
          "description": "Time window size for aggregation, in minutes.",
          "oneOf": [
            {
              "type": "integer"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "required": [
        "type"
      ],
      "type": "object"
    },
    "UserAssignedIdentity": {
      "description": "User assigned identity properties",
      "properties": {},
      "type": "object"
    },
    "WindowUptimeCriteria": {
      "description": "Represents criteria for determining uptime in window-based SLIs.",
      "properties": {
        "comparator": {
          "description": "Comparison operator used for uptime evaluation.",
          "oneOf": [
            {
              "enum": [
                "lt",
                "gt",
                "lte",
                "gte"
              ],
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "target": {
          "description": "Threshold value used to determine uptime.",
          "oneOf": [
            {
              "type": "number"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "required": [
        "target",
        "comparator"
      ],
      "type": "object"
    }
  }
}