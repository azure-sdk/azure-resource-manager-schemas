{
  "id": "https://schema.management.azure.com/schemas/2025-05-31-preview/Microsoft.ManagedIdentity.json#",
  "title": "Microsoft.ManagedIdentity",
  "description": "Microsoft ManagedIdentity Resource Types",
  "$schema": "http://json-schema.org/draft-04/schema#",
  "resourceDefinitions": {
    "userAssignedIdentities": {
      "description": "Microsoft.ManagedIdentity/userAssignedIdentities",
      "properties": {
        "apiVersion": {
          "enum": [
            "2025-05-31-preview"
          ],
          "type": "string"
        },
        "location": {
          "description": "The geo-location where the resource lives",
          "type": "string"
        },
        "name": {
          "description": "The name of the identity resource.",
          "type": "string"
        },
        "properties": {
          "description": "The properties associated with the identity.",
          "oneOf": [
            {
              "$ref": "#/definitions/UserAssignedIdentityProperties"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "resources": {
          "items": {
            "oneOf": [
              {
                "$ref": "#/definitions/userAssignedIdentities_federatedIdentityCredentials_childResource"
              }
            ]
          },
          "type": "array"
        },
        "tags": {
          "description": "Resource tags.",
          "oneOf": [
            {
              "additionalProperties": {
                "type": "string"
              },
              "properties": {},
              "type": "object"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "type": {
          "enum": [
            "Microsoft.ManagedIdentity/userAssignedIdentities"
          ],
          "type": "string"
        }
      },
      "required": [
        "name",
        "properties",
        "apiVersion",
        "type"
      ],
      "type": "object"
    },
    "userAssignedIdentities_federatedIdentityCredentials": {
      "description": "Microsoft.ManagedIdentity/userAssignedIdentities/federatedIdentityCredentials",
      "properties": {
        "apiVersion": {
          "enum": [
            "2025-05-31-preview"
          ],
          "type": "string"
        },
        "name": {
          "description": "The name of the federated identity credential resource.",
          "oneOf": [
            {
              "pattern": "^[a-zA-Z0-9]{1}[a-zA-Z0-9-_]{2,119}$",
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "properties": {
          "description": "The properties associated with the federated identity credential.",
          "oneOf": [
            {
              "$ref": "#/definitions/FederatedIdentityCredentialProperties"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "type": {
          "enum": [
            "Microsoft.ManagedIdentity/userAssignedIdentities/federatedIdentityCredentials"
          ],
          "type": "string"
        }
      },
      "required": [
        "name",
        "properties",
        "apiVersion",
        "type"
      ],
      "type": "object"
    }
  },
  "definitions": {
    "AssignmentRestrictions": {
      "description": "Configuration to restrict identity assignment to specific resource providers or resource types.",
      "properties": {
        "providers": {
          "description": "List of resource providers or resource providers with resource types that this identity can be assigned to (case-insensitive). Examples: 'Microsoft.Compute', 'Microsoft.Storage/Accounts', 'Microsoft.Network/VirtualNetworks'.",
          "oneOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "type": "object"
    },
    "ClaimsMatchingExpression": {
      "description": "Object for defining the allowed identifiers of external identities. Introduced in 2025-01-31-preview.",
      "properties": {
        "languageVersion": {
          "description": "Specifies the version of the flexible fic language used in the expression.",
          "oneOf": [
            {
              "type": "integer"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "value": {
          "description": "Wildcard-based expression for matching incoming subject claims.",
          "type": "string"
        }
      },
      "required": [
        "value",
        "languageVersion"
      ],
      "type": "object"
    },
    "FederatedIdentityCredentialProperties": {
      "description": "The properties associated with a federated identity credential.",
      "properties": {
        "audiences": {
          "description": "The list of audiences that can appear in the issued token.",
          "oneOf": [
            {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "claimsMatchingExpression": {
          "description": "Object for defining the allowed identifiers of external identities. Either 'subject' or 'claimsMatchingExpression' must be defined, but not both. Introduced in 2025-01-31-preview.",
          "oneOf": [
            {
              "$ref": "#/definitions/ClaimsMatchingExpression"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "issuer": {
          "description": "The URL of the issuer to be trusted.",
          "type": "string"
        },
        "subject": {
          "description": "The identifier of the external identity.",
          "type": "string"
        }
      },
      "required": [
        "issuer",
        "audiences"
      ],
      "type": "object"
    },
    "UserAssignedIdentityProperties": {
      "description": "The properties associated with the user assigned identity.",
      "properties": {
        "assignmentRestrictions": {
          "description": "Restrictions on which resource providers this identity can be assigned to.",
          "oneOf": [
            {
              "$ref": "#/definitions/AssignmentRestrictions"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "isolationScope": {
          "description": "Enum to configure regional restrictions on identity assignment, as necessary.",
          "oneOf": [
            {
              "enum": [
                "None",
                "Regional"
              ],
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        }
      },
      "type": "object"
    },
    "userAssignedIdentities_federatedIdentityCredentials_childResource": {
      "description": "Microsoft.ManagedIdentity/userAssignedIdentities/federatedIdentityCredentials",
      "properties": {
        "apiVersion": {
          "enum": [
            "2025-05-31-preview"
          ],
          "type": "string"
        },
        "name": {
          "description": "The name of the federated identity credential resource.",
          "oneOf": [
            {
              "pattern": "^[a-zA-Z0-9]{1}[a-zA-Z0-9-_]{2,119}$",
              "type": "string"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "properties": {
          "description": "The properties associated with the federated identity credential.",
          "oneOf": [
            {
              "$ref": "#/definitions/FederatedIdentityCredentialProperties"
            },
            {
              "$ref": "https://schema.management.azure.com/schemas/common/definitions.json#/definitions/expression"
            }
          ]
        },
        "type": {
          "enum": [
            "federatedIdentityCredentials"
          ],
          "type": "string"
        }
      },
      "required": [
        "name",
        "properties",
        "apiVersion",
        "type"
      ],
      "type": "object"
    }
  }
}